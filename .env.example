# =============================================================================
# Grimoire — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Only ANTHROPIC_API_KEY is required. Everything else is optional.
# =============================================================================

# ── Required ──────────────────────────────────────────────────────────────────
# Claude for answer generation — console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Recommended (unlocks full production pipeline) ────────────────────────────

# Voyage-code-3.5 embeddings — free tier: 200M tokens — dash.voyageai.com
# Without this: falls back to local all-MiniLM-L6-v2 (no key needed, lower quality)
VOYAGE_API_KEY=your_voyage_key_here

# Cohere Rerank v4 — free tier: 1,000 calls/month — dashboard.cohere.com
# Without this: retrieval uses RRF fusion order (good but not reranked)
COHERE_API_KEY=your_cohere_key_here

# Tavily web search — free tier: 1,000 searches/month — app.tavily.com
# Without this: web_search tool is excluded from the agent entirely
TAVILY_API_KEY=your_tavily_key_here

# ── Optional ──────────────────────────────────────────────────────────────────

# OpenAI — only needed to run DeepEval evaluation suite
# OPENAI_API_KEY=your_openai_key_here

# LangSmith tracing — optional observability
# LANGCHAIN_API_KEY=your_langsmith_key_here
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=grimoire

# ── Storage ───────────────────────────────────────────────────────────────────
QDRANT_PATH=./qdrant_data
SQLITE_DB_PATH=./data/knowledge.db

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── RAG Tuning ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=voyage-code-3.5
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=5