# ============================================================================
# Grimoire — Frontend Dockerfile (Next.js 16 with Turbopack)
# ============================================================================
# Three-stage build:
#   1) deps    — installs node_modules from package-lock.json
#   2) builder — runs `next build` to produce the optimized standalone bundle
#   3) runner  — slim image with only the .next/standalone output + runtime
# ============================================================================

# ── Deps stage ──────────────────────────────────────────────────────────────
FROM node:20-alpine AS deps

WORKDIR /app

# Install only production deps. We copy lockfile + package.json first so
# Docker can cache this layer when only source code changes.
COPY package.json package-lock.json* ./
RUN npm ci --no-audit --no-fund


# ── Builder stage ───────────────────────────────────────────────────────────
FROM node:20-alpine AS builder

WORKDIR /app

# Pull in the deps from the previous stage
COPY --from=deps /app/node_modules ./node_modules
COPY . .

# Next.js needs to know the backend URL at build time for static optimization.
# We use a default localhost value here; docker-compose overrides this with
# the service name so the frontend talks to the backend container directly.
ARG NEXT_PUBLIC_API_URL=http://localhost:8000
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}

# Disable Next.js telemetry — no phone-home from CI/CD or production builds
ENV NEXT_TELEMETRY_DISABLED=1

# Build the production bundle. Next.js 16 + Turbopack will emit a
# standalone server bundle into .next/standalone (configured via next.config).
RUN npm run build


# ── Runner stage ────────────────────────────────────────────────────────────
FROM node:20-alpine AS runner

WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

# Non-root user for security
RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nextjs

# Copy only the production output. The standalone build includes a minimal
# node_modules with just the runtime deps Next.js actually uses.
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static
COPY --from=builder --chown=nextjs:nodejs /app/public ./public

USER nextjs

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
    CMD wget --quiet --tries=1 --spider http://localhost:3000 || exit 1

# server.js is generated by `next build` when output: 'standalone' is set
CMD ["node", "server.js"]
